{
  "buildCommand": "prisma generate && prisma migrate deploy && next build --webpack",
  "crons": [
    {
      "path": "/api/cron/import-matches",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/sync-matches",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/sync-groups",
      "schedule": "0 6 * * *"
    }
  ]
}
